# RAG-LIBRO — copiar a .env en la raíz del proyecto
# cp .env.example .env

# Proveedor preferido (documentación / llamadas directas get_llm("groq"))
LLM_PROVIDER=groq

# Orden de intento ante error API, timeout o respuesta vacía
# Groq primero: ganó benchmark Fase B 2026-05-20 (7/10 vs 6/10 del 70B en todos los k)
LLM_FALLBACK_CHAIN=groq,openrouter,mock
LLM_REQUEST_TIMEOUT=60

# Groq — https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter — https://openrouter.ai (API compatible OpenAI)
# Free tier: ~20 req/min, ~200 req/día (ver https://openrouter.ai/collections/free-models)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Principal (70B instruct, bueno para RAG / terminología técnica)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Fallback dentro de OpenRouter ante 429/5xx/timeout (smoke OK 2026-05-19)
OPENROUTER_MODEL_FALLBACK=nvidia/nemotron-3-super-120b-a12b:free
# Alternativas free para benchmark (--openrouter-model en eval_runner.py):
#   nvidia/nemotron-3-super-120b-a12b:free
#   deepseek/deepseek-v4-flash:free
#   google/gemma-4-31b-it:free
#   openrouter/free
# Deprecados o sin endpoint (no usar):
#   google/gemma-2-9b-it:free
#   qwen/qwen3.6-plus:free

# RAG — rutas relativas al directorio backend/
PDF_PATH=data/libro.pdf
FAISS_INDEX_PATH=storage/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# k=4 confirmado óptimo en Fase B: k=6/8 no mejoran PASS rate (lost-in-the-middle neutro)
RETRIEVER_K=4

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
