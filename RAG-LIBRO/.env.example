# RAG-LIBRO — copiar a .env en la raíz del proyecto
# cp .env.example .env

# Proveedor preferido (documentación / llamadas directas get_llm("groq"))
LLM_PROVIDER=groq

# Orden de intento ante error API, timeout o respuesta vacía
LLM_FALLBACK_CHAIN=openrouter,groq,mock
LLM_REQUEST_TIMEOUT=60

# Groq — https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter — https://openrouter.ai (API compatible OpenAI)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# RAG — rutas relativas al directorio backend/
PDF_PATH=data/libro.pdf
FAISS_INDEX_PATH=storage/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=4

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
